generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum CategoryType {
  EXPENSE
  INCOME
}

model User {
  id           String     @id @default(cuid())
  name         String     @db.VarChar(120)
  email        String     @unique @db.VarChar(191)
  passwordHash String     @db.VarChar(255)
  role         UserRole   @default(STAFF)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  incomes      Income[]
  expenses     Expense[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(120)
  slug        String       @unique @db.VarChar(160)
  description String?      @db.VarChar(255)
  type        CategoryType @default(EXPENSE)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  expenses    Expense[]
  incomes     Income[]

  @@map("categories")
}

model Income {
  id              String      @id @default(cuid())
  userId          String
  categoryId      String?
  productId       String?
  quantity        Int?
  hppCost         Decimal?    @db.Decimal(14, 2)
  netProfit       Decimal?    @db.Decimal(14, 2)
  customerId      String?
  source          String      @db.VarChar(160)
  description     String?     @db.VarChar(255)
  amount          Decimal     @db.Decimal(14, 2)
  transactionDate DateTime
  proofUrl        String?     @db.VarChar(255)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  product         Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  receivable      Receivable?

  @@index([userId, transactionDate])
  @@map("income")
}

model Expense {
  id              String    @id @default(cuid())
  userId          String
  categoryId      String
  productId       String?
  supplierId      String?
  title           String    @db.VarChar(160)
  note            String?   @db.VarChar(255)
  amount          Decimal   @db.Decimal(14, 2)
  transactionDate DateTime
  proofUrl        String?   @db.VarChar(255)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([userId, transactionDate])
  @@index([categoryId, transactionDate])
  @@map("expense")
}

model Product {
  id          String    @id @default(cuid())
  name        String    @unique @db.VarChar(120)
  sku         String?   @unique @db.VarChar(50)
  stock       Int       @default(0)
  price       Decimal   @db.Decimal(14, 2)
  hpp         Decimal   @db.Decimal(14, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  incomes     Income[]
  expenses    Expense[]

  @@map("products")
}

model Supplier {
  id        String    @id @default(cuid())
  name      String    @unique @db.VarChar(120)
  contact   String?   @db.VarChar(100)
  phone     String?   @db.VarChar(30)
  address   String?   @db.VarChar(255)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  expenses  Expense[]

  @@map("suppliers")
}

model Customer {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(120)
  contact     String?      @db.VarChar(100)
  phone       String?      @db.VarChar(30)
  address     String?      @db.VarChar(255)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  incomes     Income[]
  receivables Receivable[]

  @@map("customers")
}

model Receivable {
  id          String   @id @default(cuid())
  customerId  String
  incomeId    String?  @unique
  amount      Decimal  @db.Decimal(14, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(14, 2)
  status      String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  dueDate     DateTime
  notes       String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  income      Income?  @relation(fields: [incomeId], references: [id], onDelete: SetNull)

  @@map("receivables")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  String   @db.VarChar(100)
  details   String   @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}